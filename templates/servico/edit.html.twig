{% extends 'base.html.twig' %}

{% block title %}Editar Serviço{% endblock %}

{% block body %}
<main class="py-5" style="min-height: 80vh; background-color: #fdfaf3; padding-top: 160px !important;">
    <div class="container">
        <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
            <div>
                <span class="badge-premium mb-2" style="background: rgba(176, 141, 87, 0.15); color: #B08D57; padding: 8px 20px; border-radius: 50px; font-weight: 700; font-size: 0.75rem; letter-spacing: 1.5px; text-transform: uppercase; border: 1px solid rgba(176, 141, 87, 0.3); display: inline-block;">Edição</span>
                <h1 class="display-5 fw-bold text-verde mb-0" style="color: #284B3B;">Editar Serviço</h1>
                <p class="text-muted mt-2">Atualize as informações do serviço.</p>
            </div>
            
            {{ include('servico/_delete_form.html.twig') }}
        </div>

        {{ include('servico/_form.html.twig', {'button_label': 'Atualizar Serviço'}) }}
        
    </div>
</main>
{% endblock %}
